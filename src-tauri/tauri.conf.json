{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "NanaBetterCubism",
  "version": "0.1.0",
  "identifier": "com.senanana.nanabettercubism",
  "build": {
    "beforeDevCommand": "yarn dev",
    "devUrl": "http://localhost:1420",
    "beforeBuildCommand": "yarn build",
    "frontendDist": "../dist",
    "removeUnusedCommands": true
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "NanaBetterCubism",
        "width": 960,
        "height": 600,
        "minWidth": 960,
        "minHeight": 600,
        "decorations": false,
        "transparent": false,
        "shadow": true,
        "backgroundColor": "#181818",
        "visible": false
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.png",
      "icons/icon.ico"
    ]
  }
}
